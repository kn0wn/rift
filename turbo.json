{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "AUTUMN_WEBHOOK_SECRET",
    "CONVEX_ADMIN_TOKEN",
    "CONVEX_DEPLOYMENT",
    "CONVEX_SECRET_TOKEN",
    "GOOGLE_FILE_SEARCH_STORE_NAMES",
    "GOOGLE_VERTEX_RAG_CORPUS",
    "KV_REST_API_READ_ONLY_TOKEN",
    "KV_REST_API_TOKEN",
    "KV_REST_API_URL",
    "KV_URL",
    "OPENAI_FILE_SEARCH_VECTOR_STORE_IDS",
    "PUBLIC_CONVEX_SITE_URL",
    "PUBLIC_CONVEX_URL",
    "PUBLIC_SENTRY_DSN",
    "R2_ACCOUNT_ID",
    "R2_ACCESS_KEY_ID",
    "R2_BUCKET_NAME",
    "R2_PUBLIC_BASE_URL",
    "R2_SECRET_ACCESS_KEY",
    "REDIS_URL",
    "SENTRY_AUTH_TOKEN",
    "SENTRY_DSN",
    "SENTRY_ORG",
    "SENTRY_PROJECT",
    "VITE_ZERO_CACHE_URL",
    "WORKOS_API_KEY",
    "WORKOS_CLIENT_ID",
    "WORKOS_COOKIE_PASSWORD",
    "WORKOS_REDIRECT_URI",
    "WORKOS_WEBHOOK_SECRET",
    "XAI_FILE_SEARCH_VECTOR_STORE_IDS",
    "XAI_MCP_SERVER_LABEL",
    "XAI_MCP_SERVER_URL",
    "ZERO_UPSTREAM_DB"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "lint:fix": {},
    "format": {},
    "format:check": {},
    "check": {
      "dependsOn": ["^build"]
    },
    "check:watch": {
      "cache": false,
      "persistent": true
    },
    "test": {},
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "clean": {},
    "prepare": {
      "cache": false
    },
    "convex": {
      "cache": false,
      "persistent": true
    },
    "zero-cache": {
      "cache": false,
      "persistent": true
    }
  }
}
